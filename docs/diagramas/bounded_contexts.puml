@startuml Bounded Contexts

skinparam packageStyle rectangle
skinparam componentStyle rectangle

title Bounded Contexts - Logistica de Ultima Milla

package "Core Domain" {
    package "BC: Pedidos" <<Rectangle>> #LightBlue {
        [Pedido] as P
        [EstadoPedido] as EP
        [PedidoFactory] as PF
        [PedidoBuilder] as PB
        [ValidadorPedido] as VP
        note right of P
            Aggregate Root
            9 estados (State pattern)
        end note
    }

    package "BC: Repartidores" <<Rectangle>> #LightGreen {
        [Repartidor] as R
        [DriverPool] as DP
        [Capacidad] as C
        [Ubicacion] as U
        note right of DP
            Singleton pattern
        end note
    }

    package "BC: Despacho" <<Rectangle>> #LightYellow {
        [Asignacion] as A
        [EstrategiaAsignacion] as EA
        [DespachoService] as DS
        note right of EA
            Strategy pattern
            (Proximidad, Capacidad, RoundRobin)
        end note
        note right of DS
            Facade pattern
        end note
    }
}

package "Supporting Domain" {
    package "BC: Rutas" <<Rectangle>> #LightCoral {
        [Ruta] as RT
        [Parada] as PA
    }

    package "BC: Tracking" <<Rectangle>> #Lavender {
        [EventoTracking] as ET
        [Notificacion] as N
    }
}

package "Generic Domain" {
    package "BC: Incidencias" <<Rectangle>> #MistyRose {
        [Incidencia] as I
        [EstadoIncidencia] as EI
        [Resolucion] as RE
        note right of I
            Aggregate Root
            4 estados (State pattern)
        end note
    }
}

package "Shared Kernel" <<Rectangle>> #WhiteSmoke {
    [Direccion] as DIR
    [ContactInfo] as CI
    [DomainEvent] as DE
    [EventBus] as EB
}

@enduml
